# Copy to .env and fill in real values. Never commit .env.

# --- Database ---
# Local dev (Docker Compose):
#   postgresql://sherwoods:sherwoods_dev_pw@localhost:5432/sherwoods_gallery
# Production: use your xCloud Postgres connection string.
DATABASE_URI=

# --- Payload ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=

# --- Public site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Mailgun (P8) ---
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=
# MAILGUN_FROM_EMAIL=
# MAILGUN_NOTIFY_TO=art@sherwoodsgallery.com

# --- Cloudflare Turnstile (P8) ---
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# --- Google Analytics (P12) ---
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
